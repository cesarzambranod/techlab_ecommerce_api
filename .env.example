# ============================================
# TechLab E-Commerce - Variables de Entorno
# ============================================
# Copia este archivo a .env y completa los valores

# ============================================
# BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=techlab_db
DB_USER=techlab_user
DB_PASSWORD=tu_password_seguro_aqui

# ============================================
# JWT - Autenticación
# ============================================
JWT_SECRET=tu_secret_key_super_larga_y_segura_minimo_256_bits
JWT_EXPIRATION=86400000

# ============================================
# SERVIDOR
# ============================================
SERVER_PORT=8080

# ============================================
# PROFILE
# ============================================
SPRING_PROFILES_ACTIVE=default
